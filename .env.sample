### Required for chakula_api
# ── App ──
NODE_ENV=production
PORT=3000

# ── PostgreSQL ──
POSTGRES_USER=chakula
POSTGRES_PASSWORD=<strong-password>
POSTGRES_DB=chakula
POSTGRES_HOST=<db-host-or-ip>
POSTGRES_PORT=5432
PG_POOL_MAX=50

# ── Redis ──
REDIS_HOST=<redis-host-or-ip>
REDIS_PORT=6379
REDIS_PASSWORD=<strong-password>

# ── JWT ──
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=<64-char-hex>
JWT_REFRESH_SECRET=<64-char-hex>
JWT_ACCESS_EXPIRY=120m
JWT_REFRESH_EXPIRY=7d

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=200

# ── Knowledge Base API ──
KNOWLEDGE_BASE_URL=http://<knowledge-base-host>:8000
KNOWLEDGE_BASE_API_KEY=<your-api-key>

# ── AWS S3 ──
S3_AWS_ACCESS_KEY_ID=<access-key-id>
S3_AWS_SECRET_ACCESS_KEY=<secret-access-key>
S3_AWS_REGION=ap-south-1
S3_BUCKET_NAME=<bucket-name>


#### Required for Knowledge Base API
